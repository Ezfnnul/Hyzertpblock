    lbl.Text="🎯 Slot "..slotNum.." — CIBLE TP"
    RunService.Heartbeat:Connect(function()
        if hl and hl.Parent then hl.FillColor=rbw() end
        if lbl and lbl.Parent then lbl.TextColor3=rbw() end
    end)
end

