-- RAINBOW
-- ════════════════════════════════════════════════════════════
local rainbowClock = 0
local function hsv(h,s,v)
    local i=math.floor(h*6); local f=h*6-i
    local p,q,t=v*(1-s),v*(1-f*s),v*(1-(1-f)*s)
    i=i%6
    if i==0 then return Color3.new(v,t,p) elseif i==1 then return Color3.new(q,v,p)
    elseif i==2 then return Color3.new(p,v,t) elseif i==3 then return Color3.new(p,q,v)
    elseif i==4 then return Color3.new(t,p,v) else return Color3.new(v,p,q) end
end
local function rbw() return hsv((rainbowClock%4)/4,1,1) end

-- ════════════════════════════════════════════════════════════
-- FIND CLONE IN BASE
-- ════════════════════════════════════════════════════════════
local function findCloneInBases()
    local plots=workspace:FindFirstChild("Plots"); if not plots then return nil,nil end
    for _,plot in ipairs(plots:GetChildren()) do
        for _,obj in ipairs(plot:GetDescendants()) do
            if (obj:IsA("Model") or obj:IsA("BasePart")) and obj.Name==player.Name then
                for _,plr in ipairs(Players:GetPlayers()) do
                    if plr~=player and plr.Name==plot.Name then return plr,plot end
                end
                local sign=plot:FindFirstChild("PlotSign")
                if sign then
                    for _,tag in ipairs({"OwnerName","PlayerName"}) do
                        local nt=sign:FindFirstChild(tag)
                        if nt then local plr=Players:FindFirstChild(nt.Text); if plr and plr~=player then return plr,plot end end
                    end
                end
            end
        end
    end
    return nil,nil
end

local function findBrainrotAtSlot(plot,slotNum)
    if not plot then return nil end
    local pods=plot:FindFirstChild("AnimalPodiums"); if not pods then return nil end
    local pod=pods:FindFirstChild(tostring(slotNum)); if not pod then return nil end
    local base=pod:FindFirstChild("Base"); if not base then return nil end
    local spwn=base:FindFirstChild("Spawn"); if not spwn then return nil end
    for _,c in ipairs(spwn:GetChildren()) do if c:IsA("Model") or c:IsA("BasePart") then return c end end
    for _,d in ipairs(spwn:GetDescendants()) do if d:IsA("Model") or (d:IsA("BasePart") and d.Name~="Base") then return d end end
    return nil
end

local function getBrainrotPosition(plot,slotNum)
    local model=findBrainrotAtSlot(plot,slotNum); if not model then return nil end
    if model:IsA("Model") then
        if model.PrimaryPart then return model.PrimaryPart.Position end
        local ok,cf=pcall(function() return model:GetBoundingBox() end)
        if ok and cf then return cf.Position end
        local p=model:FindFirstChildWhichIsA("BasePart"); if p then return p.Position end
    elseif model:IsA("BasePart") then return model.Position end
    return nil
end

