local function clearSlotESP()
    if slotESPHighlight and slotESPHighlight.Parent then slotESPHighlight:Destroy() end
    if slotESPBillboard and slotESPBillboard.Parent then slotESPBillboard:Destroy() end
    slotESPHighlight=nil; slotESPBillboard=nil
end

local function showSlotESP(plot,slotNum)
    clearSlotESP()
    local model=findBrainrotAtSlot(plot,slotNum); if not model then return end
    local hl=Instance.new("Highlight")
    hl.FillTransparency=0.25; hl.OutlineTransparency=0
    hl.FillColor=rbw(); hl.OutlineColor=Color3.fromRGB(255,255,255)
    hl.Adornee=model; hl.Parent=workspace
    slotESPHighlight=hl
    local anchor=model:IsA("Model")and(model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart"))or model
    local bb=Instance.new("BillboardGui")
    bb.AlwaysOnTop=true; bb.Size=UDim2.new(0,200,0,46)
    bb.StudsOffset=Vector3.new(0,5,0); bb.Adornee=anchor; bb.Parent=workspace
    slotESPBillboard=bb
    local lbl=Instance.new("TextLabel",bb)
    lbl.Size=UDim2.new(1,0,1,0); lbl.BackgroundTransparency=1
    lbl.Font=Enum.Font.GothamBold; lbl.TextSize=14
