-- Fonction qui repositionne les boutons scroll selon OuterFrame
local function syncScrollBtnPositions()
    local op = OuterFrame.Position
    local ox = op.X.Offset  -- offset pixel
    local oy = op.Y.Offset

    -- ▲ : en haut à droite du panel
    ScrollUpBtn.Position   = UDim2.new(op.X.Scale, ox + PANEL_W + 4, op.Y.Scale, oy + 4)
    -- ▼ : juste en dessous de ▲
    ScrollDownBtn.Position = UDim2.new(op.X.Scale, ox + PANEL_W + 4, op.Y.Scale, oy + 30)
end
