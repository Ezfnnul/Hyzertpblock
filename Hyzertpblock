-- ── Logique scroll ───────────────────────────────────────────
local maxScroll = CONTENT_H - PANEL_H   -- 360 - 300 = 60

local function applyScroll(newOffset)
    newOffset = math.clamp(newOffset, 0, maxScroll)
    scrollOffset = newOffset
    TweenService:Create(ContentFrame, TweenInfo.new(0.12, Enum.EasingStyle.Quad),
        {Position = UDim2.new(0,0,0,-scrollOffset)}):Play()
    -- Indicateur visuel sur les boutons
    ScrollUpBtn.TextColor3   = scrollOffset>0
        and Color3.fromRGB(200,160,255) or Color3.fromRGB(80,60,100)
    ScrollDownBtn.TextColor3 = scrollOffset<maxScroll
        and Color3.fromRGB(200,160,255) or Color3.fromRGB(80,60,100)
end

ScrollUpBtn.MouseButton1Click:Connect(function()
    applyScroll(scrollOffset - SCROLL_STEP)
end)
ScrollDownBtn.MouseButton1Click:Connect(function()
    applyScroll(scrollOffset + SCROLL_STEP)
end)

